<Window x:Class="Project2_Multichat_UDP_Protocol.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Project2_Multichat_UDP_Protocol"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <DockPanel Margin="5">
        <DockPanel DockPanel.Dock="Top">
            <Label Padding="10" Background="AliceBlue">Messaage</Label>
            <Button DockPanel.Dock="Right" Padding="10" Margin="5" Click="Send_Button_Click" Background="AntiqueWhite">Send</Button>
            <Button DockPanel.Dock="Right" Padding="10" Margin="5" Click="Join_Button_Click" Background="Aqua">Join</Button>
            <Button DockPanel.Dock="Right" Padding="10" Margin="5" Click="Leave_Button_Click" Background="Aquamarine">Leave</Button>
            <TextBox Margin="5" Padding="5"  
                     VerticalAlignment="Center"
                     DockPanel.Dock="Right"
                     x:Name="nicknameTextBox"
                     Width="100"
                     Background="Azure"></TextBox>
            <Label Padding="10" DockPanel.Dock="Right" Background="Beige">NickName</Label>
            <TextBox Margin="5" Padding="5" 
                     VerticalAlignment="Center"
                     DockPanel.Dock="Left"
                     x:Name="msgTextBox"
                     Background ="Bisque"></TextBox>
        </DockPanel>
        <TextBlock DockPanel.Dock="Top" TextAlignment="Center"
                   FontSize="20" FontWeight="Bold" Padding="10" Background="BlanchedAlmond">Chat</TextBlock>
        <ListBox ItemsSource="{Binding}" Background="Cornsilk"></ListBox>
    </DockPanel>
</Window>
