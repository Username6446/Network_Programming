<Window x:Class="Project6_Gmail_FInal.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Project6_Gmail_FInal"
        mc:Ignorable="d" 
        Title="Головна" Height="450" Width="800">

    <DockPanel LastChildFill="True">
        <Border DockPanel.Dock="Top" Background="White" BorderBrush="#EEEEEE" BorderThickness="0,0,0,1" Padding="15,10">
            <Grid>
                <TextBlock Text="Вхідні" FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center"/>

                <Button Content="Написати" 
                        HorizontalAlignment="Right" 
                        Padding="15,5" 
                        Background="#0078D4" 
                        Foreground="White" 
                        FontWeight="Bold"
                        Width="100"
                        Height="40"
                        Click="Button_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="5"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </Grid>
        </Border>

        <ListBox x:Name="emailsListBox" MouseDoubleClick="emailsListBox_MouseDoubleClick" BorderThickness="0">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Margin="5">
                        <TextBlock Text="{Binding Subject}" FontWeight="Bold" FontSize="14"/>
                        <TextBlock Text="{Binding From}" Foreground="Gray" FontSize="12"/>
                        <TextBlock Text="{Binding Date}" FontSize="10"/>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </DockPanel>
</Window>