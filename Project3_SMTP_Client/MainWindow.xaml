<Window x:Class="Project3_SMTP_Client.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SMTP Mail Client" Height="550" Width="850" Background="#F0F2F5">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Height" Value="35"/>
            <Setter Property="Margin" Value="10,5,10,5"/>
            <Setter Property="Background" Value="#0078D4"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#005A9E"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="Control" x:Key="InputStyle">
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="BorderBrush" Value="#D1D1D1"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#FFFFFF" Offset="0"/>
                <GradientStop Color="#E2E8F0" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <DockPanel Margin="20">
            <Grid DockPanel.Dock="Top" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="3*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Label Grid.Row="0" VerticalAlignment="Center">From:</Label>
                <TextBox x:Name="fromTb" Grid.Column="1" Grid.Row="0" Style="{StaticResource InputStyle}"/>

                <Label Grid.Row="1" VerticalAlignment="Center">To:</Label>
                <TextBox x:Name="toTb" Grid.Column="1" Grid.Row="1" Style="{StaticResource InputStyle}"/>

                <Label Grid.Row="2" VerticalAlignment="Center">Subject:</Label>
                <TextBox x:Name="subjectTb" Grid.Column="1" Grid.Row="2" Style="{StaticResource InputStyle}"/>

                <Label Grid.Row="3" VerticalAlignment="Center">Priority:</Label>
                <ComboBox x:Name="priorityCb" Grid.Column="1" Grid.Row="3" Style="{StaticResource InputStyle}"/>
            </Grid>

            <Button DockPanel.Dock="Top" Click="Button_Pin" Content="📎 Attach Files"/>

            <ListBox DockPanel.Dock="Top" Height="80" Margin="10,5" 
                     ItemsSource="{Binding}" BorderBrush="#D1D1D1" Background="#F8F9FA"/>

            <Button DockPanel.Dock="Bottom" Click="Button_Send" Content="🚀 Send Message" 
                    Background="#28A745" Height="45"/>

            <GroupBox Header="Message Body" Margin="10,10,10,5">
                <TextBox x:Name="messageTb" AcceptsReturn="True" TextWrapping="Wrap" 
                         VerticalScrollBarVisibility="Auto" BorderThickness="0"/>
            </GroupBox>
        </DockPanel>
    </Grid>
</Window>